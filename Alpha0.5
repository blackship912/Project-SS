/* ─── helpers ─── */
let ap=null; // active property
function now(){
  const d=new Date(),z=n=>String(n).padStart(2,"0");
  return `${d.getFullYear()}/${d.getMonth()+1}/${d.getDate()} ${z(d.getHours())}:${z(d.getMinutes())}`;
}
function log(p,t){p.logs.unshift({d:now(),t});if(ap===p)renderLog(p);}
function calcStats(p){
  const total=p.checks.length,unc=p.checks.filter(c=>c.i===0).length;
  return {pct:total?Math.round((total-unc)/total*100):0,unc};
}
function bumpScore(p,delta){
  const b=p.score; p.score=Math.max(0,Math.min(100,p.score+delta));
  log(p,`⭐ Score ${b} → ${p.score}`);
}

/* ─── home ─── */
let filterSt="all";
function renderHome(){renderHero();renderChips();renderList();}
function renderHero(){
  const top=[...props].sort((a,b)=>b.score-a.score)[0],m=SM[top.status];
  const cnt={}; SO.forEach(s=>cnt[s]=0); props.forEach(p=>cnt[p.status]++);
  document.getElementById("homeHero").innerHTML=`
    <div class="top">
      <div>
        <p class="score-label">注目物件 Shonai Score</p>
        <p class="score-num">${top.score}<small>/100</small></p>
        <span class="pill" style="background:${m.bg};color:${m.fg}">${m.e} ${top.status}・${top.title}</span>
      </div>
      <div class="ring" style="--p:${top.score}"><i>${top.score}</i></div>
    </div>
    <p class="score-comment">${top.comment}</p>
    <p class="score-substats">${SO.map(s=>`${s} ${cnt[s]}件`).join(" ・ ")}</p>`;
}
function renderChips(){
  const w=document.getElementById("statusChips");
  const all=[["all","すべて"],...SO.map(s=>[s,s])];
  w.innerHTML=all.map(([k,l])=>`<button class="chip ${k===filterSt?"active":""}" data-f="${k}">${l}</button>`).join("");
  w.querySelectorAll(".chip").forEach(b=>b.addEventListener("click",()=>{filterSt=b.dataset.f;renderChips();renderList();}));
}
function renderList(){
  const q=document.getElementById("search").value.trim().toLowerCase();
  const el=document.getElementById("propList"); el.innerHTML="";
  props.filter(p=>filterSt==="all"||p.status===filterSt)
    .filter(p=>JSON.stringify(p).toLowerCase().includes(q))
    .forEach(p=>{
      const m=SM[p.status];
      const div=document.createElement("article"); div.className="card prop-card";
      const thumbStyle=p.photos.length?`background-image:url(${p.photos[0].src})`:`background:linear-gradient(135deg,${m.gr[0]},${m.gr[1]})`;
      div.innerHTML=`<div class="thumb" style="${thumbStyle}">${p.photos.length?"":"🏠"}</div>
        <div class="pc-body">
          <div class="pc-top"><div><p class="ptitle">${p.title}</p><p class="addr">${p.address}</p></div>
          <span class="sbadge" style="background:${m.bg};color:${m.fg}">${p.status}</span></div>
          <div class="pc-metrics"><div><b>${p.score}</b>点</div><div><b>${p.price}</b></div><div><b>${p.yieldRate}</b>利回り</div></div>
          <div class="ptags">${p.tags.map(t=>`<span class="ptag">${t}</span>`).join("")}</div>
          ${p.reason?`<div class="reason-box">見送り理由：${p.reason}</div>`:""}
        </div>`;
      div.addEventListener("click",()=>openDetail(p));
      el.appendChild(div);
    });
}
document.getElementById("search").addEventListener("input",renderList);

/* ─── detail open/close ─── */
const shell=document.getElementById("shell");
function openDetail(p){
  ap=p; shell.classList.add("detail-open");
  document.getElementById("statusBar").style.display="";
  document.getElementById("detailScreen").scrollTop=0;
  galIdx=0; renderDetail(p);
}
function closeDetail(){
  shell.classList.remove("detail-open");
  document.getElementById("statusBar").style.display="none";
  setTimeout(()=>renderHome(),350);
}
