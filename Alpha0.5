let fsIdx=0;
const fsEl=document.getElementById("fsView");
function openFS(p,idx){
  fsIdx=idx;
  const track=document.getElementById("fsTrack"),n=p.photos.length;
  track.innerHTML=p.photos.map(ph=>`<div class="fs-slide"><img src="${ph.src}" /></div>`).join("");
  track.style.transition="none";
  track.style.transform=`translateX(${-fsIdx*100}%)`;
  document.getElementById("fsCounter").textContent=`${fsIdx+1} / ${n}`;
  renderFsFoot(p,fsIdx);
  fsEl.classList.add("show");

  const body=fsEl.querySelector(".fs-body");
  let sx=0,drag=false,base=0;
  function goFS(i,anim=true){
    fsIdx=Math.max(0,Math.min(n-1,i));
    track.style.transition=anim?"transform .3s ease":"none";
    track.style.transform=`translateX(${-fsIdx*100}%)`;
    document.getElementById("fsCounter").textContent=`${fsIdx+1} / ${n}`;
    renderFsFoot(p,fsIdx); galIdx=fsIdx;
  }
  body.ontouchstart=e=>{sx=e.touches[0].clientX;drag=true;track.style.transition="none";base=-fsIdx*body.clientWidth;};
  body.ontouchmove=e=>{if(!drag)return;track.style.transform=`translateX(${base+(e.touches[0].clientX-sx)}px)`;};
  body.ontouchend=e=>{if(!drag)return;drag=false;const dx=e.changedTouches[0].clientX-sx;Math.abs(dx)>50?(dx<0?goFS(fsIdx+1):goFS(fsIdx-1)):goFS(fsIdx);};
}
function renderFsFoot(p,idx){
  const ph=p.photos[idx];
  const tags=ph&&ph.tags.length?ph.tags.map(t=>`<span>${t}</span>`).join(""):"<span style='opacity:.5'>タグなし</span>";
  const memo=ph&&ph.memo?`<span>📝 ${ph.memo.slice(0,24)}${ph.memo.length>24?"…":""}</span>`:"";
  document.getElementById("fsFoot").innerHTML=tags+memo;
}
