  w.innerHTML=PTAGS.map(t=>`<button class="gal-tag-btn ${ph.tags.includes(t)?"on":""}" data-t="${t}">${t}</button>`).join("");
  document.querySelectorAll("#galTagWrap .gal-tag-btn").forEach(btn=>{
    btn.addEventListener("click",()=>toggleTag(p,galIdx,btn.dataset.t,!ph.tags.includes(btn.dataset.t)));
