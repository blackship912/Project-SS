 memos:[],photos:[],
 logs:[{d:"2026/6/24 09:02",t:"🏠 物件登録"},{d:"2026/6/27 18:40",t:"⭐ Score 65 → 72"},{d:"2026/6/29 21:05",t:"🟡 ステータス変更：候補 → 調査中"}]},
{id:3,title:"C町 空き家",address:"山形県酒田市□□町",status:"見送り",score:54,
 price:"390万円",yieldRate:"14.1%",rent:"50,000円/月",station:"酒田駅 徒歩22分",
 age:"41年（H15年）",structure:"軽量鉄骨",occupancy:"空家",buildingArea:"88.00㎡（26.6坪）",
 floorPlan:"3DK",landArea:"140.00㎡（42坪）",parking:"1台",road:"接道義務未確認",
