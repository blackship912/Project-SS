let wizStep=0,wizDraft={};
function openWiz(){
  wizStep=0; wizDraft={...ap};
  renderWizStep(); openSh("eBd","eSheet");
}
function renderWizStep(){
  const s=STEPS[wizStep];
  document.getElementById("wizProg").innerHTML=STEPS.map((_,i)=>`<i class="${i<=wizStep?"done":""}"></i>`).join("");
  document.getElementById("wizStepName").textContent=`STEP ${wizStep+1}/${STEPS.length}　${s.name}`;
  document.getElementById("wizFields").innerHTML=s.fields.map(f=>{
    if(f.sel)return`<div class="ff"><label>${f.l}</label><select id="wf_${f.k}">${f.sel.map(o=>`<option${wizDraft[f.k]===o?" selected":""}>${o}</option>`).join("")}</select></div>`;
    return`<div class="ff"><label>${f.l}</label><input id="wf_${f.k}" value="${wizDraft[f.k]||""}"></div>`;
  }).join("");
  document.getElementById("wizBack").textContent=wizStep===0?"キャンセル":"戻る";
  document.getElementById("wizNext").textContent=wizStep===STEPS.length-1?"保存する":"次へ";
}
function captureWiz(){STEPS[wizStep].fields.forEach(f=>{wizDraft[f.k]=document.getElementById("wf_"+f.k).value;});}
document.getElementById("wizBack").addEventListener("click",()=>{
  if(wizStep===0){closeSh("eBd","eSheet");return;}
  captureWiz(); wizStep--; renderWizStep();
});
document.getElementById("wizNext").addEventListener("click",()=>{
  captureWiz();
  if(wizStep<STEPS.length-1){wizStep++;renderWizStep();return;}
  const p=ap,allF=STEPS.flatMap(s=>s.fields);
  let changed=0;
  allF.forEach(f=>{if(p[f.k]!==wizDraft[f.k]){log(p,`✏️ ${f.l}：${p[f.k]} → ${wizDraft[f.k]}`);p[f.k]=wizDraft[f.k];changed++;}});
  if(changed===0)log(p,"✏️ 基本情報を確認しました");
  else{const d=Math.floor(Math.random()*5)-1;if(d!==0)bumpScore(p,d);}
  renderDetail(p); closeSh("eBd","eSheet");
});
