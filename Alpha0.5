/* ─── radar svg ─── */
function radarSVG(bd){
  const s=170,c=s/2,r=s/2-28,max=20,n=bd.length;
  const pt=(i,v)=>{const a=(Math.PI*2*i/n)-Math.PI/2,rr=r*(v/max);return [c+rr*Math.cos(a),c+rr*Math.sin(a)];};
  const poly=bd.map((b,i)=>pt(i,b[1]).join(",")).join(" ");
  let ax="",lb="",ri="";
  [.33,.66,1].forEach(f=>{ri+=`<circle cx="${c}" cy="${c}" r="${r*f}" fill="none" stroke="#e3ede5" stroke-width="1"/>`;});
  bd.forEach((b,i)=>{
    const[ax1,ay1]=pt(i,max); ax+=`<line x1="${c}" y1="${c}" x2="${ax1.toFixed(1)}" y2="${ay1.toFixed(1)}" stroke="#dbe9df" stroke-width="1"/>`;
    const[lx,ly]=pt(i,max*1.2); lb+=`<text x="${lx.toFixed(1)}" y="${ly.toFixed(1)}" font-size="9" fill="#4d5c51" font-weight="700" text-anchor="middle" dominant-baseline="middle">${b[0]}</text>`;
  });
  return `<svg width="${s}" height="${s}" viewBox="0 0 ${s} ${s}">${ri}${ax}<polygon points="${poly}" fill="#1f7a45" fill-opacity=".3" stroke="#1f7a45" stroke-width="2"/>${lb}</svg>`;
}

