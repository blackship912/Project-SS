function toggleTag(p,idx,tag,add){
  const ph=p.photos[idx];
  if(add){if(!ph.tags.includes(tag)){ph.tags.push(tag);log(p,`🏷️ 写真タグ追加：${tag}`);}}
  else{ph.tags=ph.tags.filter(t=>t!==tag);log(p,`🏷️ 写真タグ削除：${tag}`);}
  renderTagArea(p);
  if(document.getElementById("fsView").classList.contains("show"))renderFsFoot(p,idx);
}

