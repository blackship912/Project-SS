  "接道状況":[["未確認","bu"],["問題なし","bg"],["要確認","bw"],["違反","bb"]],
  "修繕履歴":[["未確認","bu"],["良好","bg"],["一部修繕済","bw"],["要修繕","bb"]],
  "給排水設備":[["未確認","bu"],["問題なし","bg"],["老朽化","bw"],["交換済","bg"]],
  "空室理由":[["未確認","bu"],["判明","bg"],["不明","bw"]],
  "家賃根拠":[["未確認","bu"],["妥当","bg"],["やや高め","bw"],["やや低め","bw"]],
  "固定資産税":[["未確認","bu"],["確認済","bg"],["要確認","bw"]],
  "周辺環境":[["未確認","bu"],["良好","bg"],["騒音あり","bw"],["臭気あり","bw"]],
  "災害リスク":[["未確認","bu"],["リスクなし","bg"],["浸水域","bb"],["土砂災害域","bb"]],
  "その他法令":[["未確認","bu"],["問題なし","bg"],["要確認","bw"],["違反","bb"]]
};
function ck(label){return CK[label]||[["未確認","bu"],["問題なし","bg"],["要確認","bw"],["問題あり","bb"]];}
function dotCls(c){return c==="bg"?"#1f7a45":c==="bw"?"#d99a1f":c==="bb"?"#c0392b":"#9aa6a0";}

const PTAGS=["🏠 外観","🛋 リビング","🍳 キッチン","🛁 浴室","🚽 トイレ","🅿 駐車場","🌿 庭","⚡設備","📦 その他"];

const STEPS=[
  {name:"価格・収益",fields:[{k:"price",l:"価格"},{k:"yieldRate",l:"利回り"},{k:"rent",l:"家賃（満室想定）"},{k:"age",l:"築年数"}]},
  {name:"建物情報",fields:[{k:"structure",l:"構造"},{k:"occupancy",l:"現況",sel:["賃貸中","空室","空家","自己使用"]},{k:"buildingArea",l:"建物面積"},{k:"landArea",l:"土地面積"},{k:"floorPlan",l:"間取り"}]},
  {name:"立地・その他",fields:[{k:"parking",l:"駐車場"},{k:"road",l:"接道"},{k:"zoning",l:"用途地域"},{k:"source",l:"情報源"}]}
];

/* ─── data ─── */
const props=[
