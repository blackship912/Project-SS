  const ps=p.status; p.status=ns; p.reason=ns==="見送り"?(reason||p.reason||""):null;
  const m=SM[ns]; log(p,`${m.e} ステータス変更：${ps} → ${ns}`);
  if(ns==="見送り"&&p.reason)log(p,`📝 見送り理由：${p.reason}`);
  if(ap===p)renderDetail(p);
}
