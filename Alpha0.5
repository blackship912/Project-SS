<!doctype html>
<html lang="ja">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<title>Project:SS Alpha 0.5</title>
<style>
:root{--g:#1f7a45;--g2:#7ecb91;--ink:#17251b;--muted:#7a8780;--bg:#eef5ef;--card:#fff}
*{box-sizing:border-box;-webkit-tap-highlight-color:transparent}
html,body{height:100%}
body{margin:0;background:var(--bg);font-family:-apple-system,BlinkMacSystemFont,"Hiragino Sans","Segoe UI",sans-serif;color:var(--ink);-webkit-font-smoothing:antialiased}
button{font-family:inherit;cursor:pointer}
button:active{transform:scale(.96);transition:transform .12s}
p,h1,h2,h3{margin:0}
input,textarea,select{font-family:inherit}

/* ── shell / screens ── */
.shell{width:min(430px,100%);margin:0 auto;position:relative;height:100dvh;overflow:hidden}
.screen{position:absolute;inset:0;overflow-y:auto;-webkit-overflow-scrolling:touch;background:#f8fbf8;
  padding:16px 16px 0;padding-top:calc(16px + env(safe-area-inset-top));
  transition:transform .42s cubic-bezier(.22,.7,.36,1)}
#homeScreen{transform:translateX(0);padding-bottom:calc(100px + env(safe-area-inset-bottom))}
#detailScreen{transform:translateX(102%);padding-bottom:calc(112px + env(safe-area-inset-bottom))}
.shell.detail-open #homeScreen{transform:translateX(-26%)}
.shell.detail-open #detailScreen{transform:translateX(0)}

/* ── topbar ── */
.topbar{display:flex;justify-content:space-between;align-items:center;margin-bottom:14px}
.brand{display:flex;gap:11px;align-items:center}
.logo{width:44px;height:44px;border-radius:14px;background:linear-gradient(135deg,var(--g),var(--g2));color:#fff;font-weight:800;display:grid;place-items:center;box-shadow:0 8px 18px rgba(31,122,69,.24);font-size:14px}
h1{font-size:19px;font-weight:800}
.sub{font-size:11px;color:var(--g);font-weight:800;letter-spacing:.04em}
.detail-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:0;padding-bottom:12px}
.round{border:0;background:#fff;color:var(--g);width:40px;height:40px;border-radius:50%;font-size:18px;box-shadow:0 6px 16px rgba(32,59,41,.1);display:grid;place-items:center}
.tiny{font-size:11px;color:var(--muted);display:block}

/* ── card ── */
.card{background:var(--card);border-radius:24px;padding:18px;box-shadow:0 12px 28px rgba(32,59,41,.08);margin-bottom:14px}
.card-title{display:flex;align-items:center;gap:8px;font-weight:800;font-size:14.5px;margin:0 0 12px}
.ctrow{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px}
.link-btn{border:1.5px solid #cfe6d7;background:#fff;color:var(--g);font-size:12px;font-weight:800;border-radius:999px;padding:6px 13px}

/* ── score hero ── */
.score-hero{background:linear-gradient(135deg,#fff,#e9f8ee)}
.score-hero .top{display:flex;justify-content:space-between;align-items:center}
.score-label{font-size:12px;color:var(--g);font-weight:800;letter-spacing:.02em;margin-bottom:4px}
.score-num{font-size:44px;font-weight:800;line-height:1}
.score-num small{font-size:14px;color:var(--muted);font-weight:700}
.pill{display:inline-flex;align-items:center;gap:5px;margin-top:8px;font-size:11px;font-weight:800;border-radius:999px;padding:6px 12px;transition:background .25s,color .25s}
.ring{width:84px;height:84px;border-radius:50%;background:conic-gradient(var(--g) calc(var(--p)*1%),#e3ede5 0);display:grid;place-items:center;flex:none}
.ring i{width:64px;height:64px;border-radius:50%;background:#fff;display:grid;place-items:center;font-style:normal;font-weight:800;font-size:19px}
.score-comment{margin-top:12px;font-size:12.5px;line-height:1.75;color:#3c473f}
.score-substats{margin-top:8px;font-size:11.5px;color:var(--muted)}

/* ── home search/chips ── */
input.search{width:100%;border:0;background:#f0f5f1;padding:13px 14px;border-radius:16px;font-size:15px;outline:none}
.chips{display:flex;gap:8px;overflow-x:auto;margin-top:10px;padding-bottom:2px;-ms-overflow-style:none;scrollbar-width:none}
.chips::-webkit-scrollbar{display:none}
.chip{white-space:nowrap;border:0;border-radius:999px;padding:8px 14px;background:#edf2ee;color:#4d5c51;font-weight:700;font-size:12.5px}
.chip.active{background:var(--g);color:#fff}

/* ── property list card ── */
.prop-card{display:flex;gap:12px;cursor:pointer}
.thumb{width:56px;height:56px;border-radius:16px;flex:none;overflow:hidden;display:grid;place-items:center;font-size:22px;color:#fff;background-size:cover;background-position:center}
.pc-body{flex:1;min-width:0}
.pc-top{display:flex;justify-content:space-between;align-items:flex-start;gap:8px}
.ptitle{font-size:14.5px;font-weight:800;margin:0 0 2px}
.addr{font-size:11.5px;color:var(--muted)}
.sbadge{font-size:10.5px;font-weight:800;border-radius:999px;padding:5px 9px;flex:none}
.pc-metrics{display:flex;gap:13px;margin-top:8px;font-size:11.5px}
.pc-metrics b{font-size:13.5px}
.ptags{display:flex;gap:6px;flex-wrap:wrap;margin-top:8px}
.ptag{font-size:10.5px;background:#edf7ef;color:var(--g);border-radius:999px;padding:4px 8px}
.reason-box{margin-top:9px;padding:9px 10px;border-radius:13px;background:#fef0f0;color:#7b2d2d;font-size:11.5px;font-weight:700}

/* ── photo gallery ── */
.gallery{border-radius:24px;overflow:hidden;margin-bottom:14px;background:var(--card);box-shadow:0 12px 28px rgba(32,59,41,.08)}
.gal-empty{height:220px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;background:#f1f7f3}
.gal-empty-btn{border:0;background:var(--g);color:#fff;border-radius:999px;padding:14px 24px;font-weight:800;font-size:14px;box-shadow:0 10px 22px rgba(31,122,69,.28)}
.gal-empty p{font-size:12px;color:var(--muted)}
.gal-viewport{position:relative;height:240px;overflow:hidden;background:#1a241c;cursor:pointer}
.gal-track{display:flex;height:100%;will-change:transform;transition:transform .32s cubic-bezier(.22,.7,.36,1)}
.gal-slide{flex:none;width:100%;height:100%;background-size:cover;background-position:center}
.gal-add{position:absolute;top:10px;right:10px;width:34px;height:34px;border-radius:50%;border:0;background:rgba(0,0,0,.44);color:#fff;font-size:16px;display:grid;place-items:center;z-index:2}
.gal-counter{position:absolute;top:10px;left:10px;background:rgba(0,0,0,.42);color:#fff;font-size:11px;font-weight:700;padding:4px 10px;border-radius:999px;z-index:2}
.gal-dots{position:absolute;bottom:10px;left:0;right:0;display:flex;justify-content:center;gap:5px;z-index:2;pointer-events:none}
.gal-dots span{width:6px;height:6px;border-radius:50%;background:rgba(255,255,255,.45);transition:all .22s}
.gal-dots span.on{background:#fff;width:16px;border-radius:4px}
.gal-meta{display:flex;padding:11px 14px;border-top:1px solid #f0f3f0}
.gal-meta div{flex:1;text-align:center;font-size:11.5px;color:#3c473f}
.gal-meta div+div{border-left:1px solid #eef2ef}
.gal-meta b{display:block;font-size:13.5px}
/* photo tags + memo */
.gal-tags-area{padding:10px 14px 0}
.gal-tags-wrap{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:8px}
.gal-tag-btn{border:1.5px solid #dbe9df;background:#fff;color:#3c473f;border-radius:999px;padding:5px 10px;font-size:11.5px;font-weight:700}
.gal-tag-btn.on{background:var(--g);color:#fff;border-color:var(--g)}
.gal-custom-row{display:flex;gap:6px}
.gal-custom-row input{flex:1;border:0;background:#f0f5f1;border-radius:12px;padding:8px 10px;font-size:12.5px;outline:none}
.gal-custom-row button{border:0;background:#edf7ef;color:var(--g);border-radius:12px;padding:8px 12px;font-weight:800;font-size:12px}
.gal-memo-area{padding:8px 14px 14px}
.pm-text{background:#f4f7f5;border-radius:14px;padding:11px 12px;font-size:12.5px;line-height:1.6;display:flex;gap:8px;align-items:flex-start}
.pm-text p{flex:1}
.pm-text-actions{display:flex;gap:8px;flex:none}
.pm-text-actions button{border:0;background:none;color:var(--muted);font-size:11px;font-weight:700}
.pm-add{width:100%;border:1.5px dashed #cfe6d7;background:#fff;color:var(--g);border-radius:14px;padding:11px;font-weight:800;font-size:12.5px}
.pm-form{display:none}
.pm-form.open{display:block}
.pm-form-inner{display:flex;gap:8px;align-items:flex-end}
.pm-form-inner textarea{flex:1;border:0;background:#f0f5f1;border-radius:14px;padding:10px;min-height:60px;outline:none;resize:vertical;font-size:12.5px}
.mic-btn{width:36px;height:36px;flex:none;border:0;border-radius:50%;background:#edf7ef;color:var(--g);font-size:16px;display:grid;place-items:center}
.mic-btn.rec{background:#fbe1e1;color:#a23131;animation:micpulse 1s infinite}
@keyframes micpulse{50%{box-shadow:0 0 0 7px rgba(192,57,43,.15)}}
.pm-form-btns{display:flex;gap:8px;margin-top:8px}
.pm-form-btns button{flex:1;border:0;border-radius:12px;padding:10px;font-weight:800;font-size:12.5px}
.pm-save-btn{background:var(--g);color:#fff}
.pm-cancel-btn{background:#eee;color:#555}

/* fullscreen */
.fs{position:fixed;inset:0;background:#0c130d;z-index:60;display:flex;flex-direction:column;opacity:0;pointer-events:none;transition:opacity .25s}
.fs.show{opacity:1;pointer-events:auto}
.fs-head{display:flex;justify-content:space-between;align-items:center;padding:14px 16px;padding-top:calc(14px + env(safe-area-inset-top))}
.fs-head button{border:0;background:rgba(255,255,255,.15);color:#fff;width:38px;height:38px;border-radius:50%;font-size:18px}
.fs-head span{color:#fff;font-weight:700;font-size:13px}
.fs-body{flex:1;overflow:hidden;position:relative}
.fs-track{display:flex;height:100%;will-change:transform;transition:transform .3s cubic-bezier(.22,.7,.36,1)}
.fs-slide{flex:none;width:100%;height:100%;display:flex;align-items:center;justify-content:center}
.fs-slide img{max-width:100%;max-height:100%;object-fit:contain}
.fs-foot{padding:12px 16px calc(20px + env(safe-area-inset-bottom));display:flex;flex-wrap:wrap;gap:6px}
.fs-foot span{background:rgba(255,255,255,.14);color:#fff;font-size:11px;font-weight:700;border-radius:999px;padding:5px 10px}

/* ── anchor quicklinks ── */
.ql-wrap{display:grid;grid-template-columns:repeat(4,1fr);gap:7px;margin-bottom:14px;position:sticky;top:0;z-index:4;padding:0}
.ql{border:0;background:#fff;border-radius:18px;padding:11px 4px 10px;box-shadow:0 6px 16px rgba(32,59,41,.07);display:flex;flex-direction:column;align-items:center;gap:4px;font-size:10.5px;color:#3c473f;font-weight:700}
.ql .ico{width:30px;height:30px;border-radius:10px;background:#edf7ef;display:grid;place-items:center;font-size:14px}
.ql.on{background:var(--g);color:#fff}
.ql.on .ico{background:rgba(255,255,255,.2)}

/* ── score breakdown ── */
.radar-wrap{display:flex;justify-content:center;margin-bottom:10px}
.bd-row{display:grid;grid-template-columns:62px 1fr 36px;align-items:center;gap:8px;font-size:11px;color:#3c473f;margin-bottom:7px}
.bd-bar{height:7px;border-radius:999px;background:#eef2ef;overflow:hidden}
.bd-bar i{display:block;height:100%;background:linear-gradient(90deg,var(--g),var(--g2));border-radius:999px}

/* ── ai ── */
.ai-card{background:linear-gradient(135deg,#fff,#eef7f0)}
.ai-text{font-size:13px;line-height:1.8;color:#3c473f}
.ai-text.clamp{display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}
.ai-toggle{display:none;border:0;background:#e7f4eb;color:var(--g);border-radius:13px;padding:9px;width:100%;font-weight:800;font-size:12.5px;margin-top:9px}
.ai-sub{margin-top:13px}
.ai-sub .h{font-size:11.5px;font-weight:800;color:var(--g);margin-bottom:5px}
.ai-sub ul{margin:0;padding-left:18px;font-size:12px;line-height:1.85;color:#3c473f}

/* ── todo ── */
.todo-row{display:flex;align-items:center;gap:10px;background:#f1f5f2;border-radius:16px;padding:12px 14px;margin-top:9px}
.todo-circle{width:22px;height:22px;border-radius:50%;border:2px solid #c6d4ca;flex:none;background:#fff;display:grid;place-items:center;font-size:12px;color:transparent}
.todo-circle.done{background:var(--g);border-color:var(--g);color:#fff}
.todo-label{flex:1;font-size:13.5px;font-weight:700}
.todo-row.done .todo-label{color:#9aa6a0;text-decoration:line-through}
.todo-arr{color:#9aa6a0;font-size:15px}
.done-toggle{margin-top:11px;background:none;border:0;color:var(--muted);font-size:11.5px;font-weight:700}
.done-list{max-height:0;overflow:hidden;transition:max-height .3s ease}
.done-list.open{max-height:500px}

/* ── sections (scroll targets) ── */
.sec{scroll-margin-top:12px}

/* ── info grid ── */
.info-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}
.info-cell{background:#f4f7f5;border-radius:16px;padding:10px 6px;text-align:center}
.info-cell .ico{font-size:15px;margin-bottom:4px}
.info-cell span{display:block;font-size:10px;color:#657066;margin-bottom:3px}
.info-cell b{display:block;font-size:12px;line-height:1.3}

/* ── check ── */
.legend{display:flex;flex-wrap:wrap;gap:9px;margin-bottom:12px;font-size:10px;color:#5b6b60}
.legend i{display:inline-block;width:7px;height:7px;border-radius:50%;margin-right:4px;vertical-align:middle}
.dg{background:var(--g)}.dw{background:#d99a1f}.db{background:#c0392b}.du{background:#9aa6a0}
.check-btn{display:flex;justify-content:space-between;align-items:center;width:100%;border:0;background:none;text-align:left;padding:12px 6px;border-bottom:1px solid #eef2ef;border-radius:14px;transition:background .3s,box-shadow .3s}
.check-btn:last-child{border-bottom:0}
.cr-label{font-size:13px;font-weight:700}
.cr-note{font-size:10.5px;color:#9aa6a0;margin-top:2px}
.check-btn.hi{background:#fff6da;box-shadow:0 0 0 2px #ffd866 inset;animation:pulse 1s 2}
@keyframes pulse{50%{transform:scale(1.015)}}
.badge{font-size:10.5px;font-weight:800;border-radius:999px;padding:5px 10px;flex:none}
.bg{background:#e2f5e8;color:#14733d}.bw{background:#fdedd2;color:#8a6300}.bb{background:#fbe1e1;color:#a23131}.bu{background:#eef1f4;color:#5b6b74}
.prog-row{display:flex;align-items:center;gap:10px;margin-top:13px}
.prog-bar{flex:1;height:8px;border-radius:999px;background:#eef2ef;overflow:hidden}
.prog-bar i{display:block;height:100%;background:linear-gradient(90deg,var(--g),var(--g2));border-radius:999px;transition:width .5s}
.prog-pct{font-size:12.5px;font-weight:800;color:var(--g)}
.unconf{margin-top:9px;background:#f7f5ee;border-radius:13px;padding:8px 12px;font-size:11.5px;color:#7a6a2d;font-weight:700;display:flex;justify-content:space-between}

/* ── memo ── */
.memo-item{background:#f4f7f5;border-radius:16px;padding:12px 13px;margin-bottom:10px;position:relative}
.memo-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:4px}
.memo-head b{font-size:10.5px;color:var(--muted)}
.memo-item p{font-size:13px;line-height:1.6}
.memo-more-btn{border:0;background:none;color:var(--muted);font-size:16px;font-weight:800;padding:2px 6px}
.memo-menu{position:absolute;right:10px;top:36px;background:#fff;border-radius:14px;box-shadow:0 10px 24px rgba(0,0,0,.16);z-index:5;display:none}
.memo-menu.show{display:block}
.memo-menu button{display:block;width:110px;border:0;background:#fff;padding:11px 14px;font-size:13px;font-weight:700;text-align:left;color:#243329}
.memo-menu button.del{color:#a23131}
.memo-add-btn{width:100%;border:1.5px dashed #cfe6d7;background:#fff;color:var(--g);border-radius:16px;padding:12px;font-weight:800;font-size:13px;margin-bottom:11px}
.memo-form-wrap{display:none;margin-bottom:12px}
.memo-form-wrap.open{display:block}
.memo-form-wrap textarea{width:100%;border:0;background:#f0f5f1;border-radius:16px;padding:12px;resize:vertical;min-height:70px;outline:none;font-size:13px}
.memo-form-btns{display:flex;gap:8px;margin-top:8px}
.memo-form-btns button{flex:1;border:0;border-radius:13px;padding:11px;font-weight:800;font-size:12.5px}
.msave{background:var(--g);color:#fff}.mcancel{background:#eee;color:#555}
/* inline memo edit */
.memo-edit-form{margin-top:6px}
.memo-edit-form textarea{width:100%;border:0;background:#f0f5f1;border-radius:13px;padding:10px;min-height:60px;outline:none;font-size:13px}
.memo-edit-btns{display:flex;gap:8px;margin-top:7px}
.memo-edit-btns button{flex:1;border:0;border-radius:12px;padding:9px;font-weight:800;font-size:12px}

/* ── log ── */
.log-item{border-left:3px solid var(--g);padding:0 0 15px 13px;margin-left:6px;animation:fin .3s ease}
.log-item:last-child{padding-bottom:0}
.log-item b{font-size:11px;color:var(--muted);display:block}
.log-item p{font-weight:700;margin-top:4px;font-size:13px}
@keyframes fin{from{opacity:0;transform:translateY(-5px)}to{opacity:1;transform:translateY(0)}}

/* ── status fixed bar ── */
.status-bar{position:fixed;left:50%;transform:translateX(-50%);width:min(398px,calc(100% - 28px));bottom:calc(76px + env(safe-area-inset-bottom));z-index:6}
.status-bar button{width:100%;border:0;border-radius:18px;padding:15px;font-weight:800;font-size:14.5px;background:var(--g);color:#fff;box-shadow:0 10px 24px rgba(0,0,0,.15)}

/* ── bottom nav ── */
.bnav{position:fixed;left:50%;transform:translateX(-50%);bottom:calc(13px + env(safe-area-inset-bottom));width:min(398px,calc(100% - 28px));background:rgba(255,255,255,.94);backdrop-filter:blur(12px);border-radius:26px;display:flex;align-items:center;justify-content:space-around;padding:8px 6px;box-shadow:0 10px 30px rgba(0,0,0,.13);z-index:10}
.bnav button{border:0;background:transparent;color:#68746c;display:flex;flex-direction:column;align-items:center;gap:2px;font-size:18px;flex:1;padding:4px 0}
.bnav span{font-size:9.5px;font-weight:600}
.bnav .nav-on{color:var(--g);font-weight:800}
.nav-fab{background:var(--g) !important;color:#fff !important;width:46px;height:46px;border-radius:50%;display:grid !important;place-items:center;font-size:22px;margin-top:-18px;box-shadow:0 8px 18px rgba(31,122,69,.35)}
.nav-fab span{display:none}

/* ── backdrop / sheet ── */
.bd{position:fixed;inset:0;background:rgba(15,30,20,0);pointer-events:none;transition:background .3s;z-index:30}
.bd.show{background:rgba(15,30,20,.32);pointer-events:auto}
.sheet{position:fixed;left:0;right:0;bottom:0;width:min(430px,100%);margin:0 auto;background:#fff;border-radius:26px 26px 0 0;padding:10px 18px calc(22px + env(safe-area-inset-bottom));box-shadow:0 -16px 40px rgba(0,0,0,.18);transform:translateY(105%);transition:transform .34s cubic-bezier(.22,.7,.36,1);z-index:31;max-height:85vh;overflow-y:auto}
.sheet.show{transform:translateY(0)}
.sh-handle{width:38px;height:5px;background:#e1e7e2;border-radius:99px;margin:8px auto 14px}
.sh-title{font-size:16px;font-weight:800;margin-bottom:12px}
.sh-opt{display:flex;align-items:center;gap:10px;width:100%;border:0;background:#f5f8f6;border-radius:16px;padding:14px;margin:7px 0;font-weight:800;font-size:14px;color:#243329}
.sh-opt .dot{width:10px;height:10px;border-radius:50%;flex:none}
.sh-opt.cur{background:#e2f5e8;color:#14733d}
.sh-cancel{display:block;width:100%;border:0;background:transparent;color:#9aa6a0;font-weight:700;font-size:13.5px;padding:12px;margin-top:2px}
.reason-zone{max-height:0;overflow:hidden;transition:max-height .3s}
.reason-zone.open{max-height:180px;margin:6px 0 10px}
.reason-zone textarea{width:100%;border:0;background:#f0f5f1;border-radius:13px;padding:11px;min-height:68px;outline:none;resize:vertical;font-size:13px}
.reason-confirm{width:100%;border:0;background:var(--g);color:#fff;border-radius:13px;padding:12px;font-weight:800;margin-top:4px}

/* ── edit wizard ── */
.wiz-steps{display:flex;gap:5px;margin-bottom:14px}
.wiz-steps i{flex:1;height:4px;border-radius:999px;background:#e7ede8;font-style:normal}
.wiz-steps i.done{background:var(--g)}
.wiz-step-name{font-size:12.5px;font-weight:800;color:var(--g);margin-bottom:12px}
.ff{margin-bottom:11px}
.ff label{display:block;font-size:11.5px;color:var(--muted);font-weight:700;margin-bottom:5px}
.ff input,.ff select{width:100%;border:0;background:#f0f5f1;border-radius:13px;padding:11px;outline:none;font-size:14px}
.wiz-nav{display:flex;gap:10px;margin-top:6px}
.wiz-nav button{flex:1;border:0;border-radius:16px;padding:14px;font-weight:800;font-size:14px}
.wiz-back{background:#eef2ef;color:#4d5c51}
.wiz-next{background:var(--g);color:#fff}
</style>
</head>
<body>
<div class="shell" id="shell">

<!-- ===== HOME ===== -->
<section id="homeScreen" class="screen">
  <header class="topbar">
    <div class="brand">
      <div class="logo">SS</div>
      <div><h1>Project:SS</h1><p class="sub">Shonai Score</p></div>
    </div>
    <button style="border:0;background:#fff;color:var(--g);width:40px;height:40px;border-radius:50%;font-size:18px;box-shadow:0 6px 16px rgba(32,59,41,.1);display:grid;place-items:center">☰</button>
  </header>
  <section class="card score-hero" id="homeHero"></section>
  <section class="card">
    <input class="search" id="search" placeholder="地区・タグ・見送り理由で検索" />
    <div class="chips" id="statusChips"></div>
  </section>
  <section id="propList"></section>
</section>

<!-- ===== DETAIL ===== -->
<section id="detailScreen" class="screen">
  <header class="detail-head">
    <button class="round" id="backBtn">←</button>
    <div style="text-align:center">
      <span class="tiny">物件カルテ</span>
      <h1 id="dTitle" style="font-size:17px"></h1>
    </div>
    <button class="round">⋯</button>
  </header>

  <!-- PHOTO GALLERY -->
  <div class="gallery" id="gallery"></div>
  <input type="file" id="fileInput" accept="image/*" multiple style="display:none">

  <!-- QUICKLINKS (scroll anchors) -->
  <div class="ql-wrap" id="qlWrap">
    <button class="ql" data-sec="secBasic"><span class="ico">🏠</span>基本</button>
    <button class="ql" data-sec="secCheck"><span class="ico">📋</span>調査</button>
    <button class="ql" data-sec="secMemo"><span class="ico">📝</span>メモ</button>
    <button class="ql" data-sec="secLog"><span class="ico">🕘</span>ログ</button>
  </div>

  <!-- SCORE -->
  <section class="card score-hero">
    <div class="top">
      <div>
        <p class="score-label">Shonai Score</p>
        <p class="score-num"><span id="dScore"></span><small>/100</small></p>
        <span id="dPill" class="pill"></span>
      </div>
      <div class="ring" id="dRing"><i id="dRingNum"></i></div>
    </div>
    <p class="score-comment" id="dComment"></p>
    <p class="score-substats" id="dSub"></p>
  </section>

  <!-- SCORE BREAKDOWN -->
  <section class="card">
    <p class="card-title">📊 スコア内訳</p>
    <div class="radar-wrap" id="radar"></div>
    <div id="bdRows"></div>
  </section>

  <!-- AI -->
  <section class="card ai-card">
    <p class="card-title">🤖 AIアドバイス</p>
    <p class="ai-text clamp" id="aiText"></p>
    <button class="ai-toggle" id="aiToggle">続きを読む</button>
    <div class="ai-sub"><p class="h">⭐ 重要ポイント</p><ul id="aiPts"></ul></div>
    <div class="ai-sub"><p class="h">🔎 次に確認すること</p><ul id="aiNext"></ul></div>
  </section>

  <!-- TODO -->
  <section class="card">
    <p class="card-title">✅ 次にやること</p>
    <div id="todoActive"></div>
    <button class="done-toggle" id="doneToggle">完了済み (<span id="doneCount">0</span>) ▾</button>
    <div class="done-list" id="doneList"></div>
  </section>

  <!-- 基本情報 -->
  <section class="card sec" id="secBasic">
    <div class="ctrow">
      <p class="card-title" style="margin:0">🏠 基本情報</p>
      <button class="link-btn" id="editBtn">編集</button>
    </div>
    <div class="info-grid" id="infoGrid"></div>
  </section>

  <!-- 調査 -->
  <section class="card sec" id="secCheck">
    <p class="card-title">📋 調査チェック</p>
    <div class="legend">
      <span><i class="dg"></i>良好</span><span><i class="dw"></i>要確認</span>
      <span><i class="db"></i>問題あり</span><span><i class="du"></i>未確認</span>
    </div>
    <div id="checkRows"></div>
    <div class="prog-row">
      <span style="font-size:12px;font-weight:800;white-space:nowrap">調査完了率</span>
      <div class="prog-bar"><i id="progFill"></i></div>
      <span class="prog-pct" id="progPct"></span>
    </div>
    <div class="unconf"><span>未確認項目</span><span id="unconfN"></span></div>
  </section>

  <!-- メモ -->
  <section class="card sec" id="secMemo">
    <p class="card-title">📝 メモ</p>
    <button class="memo-add-btn" id="memoAddBtn">＋ メモを追加</button>
    <div class="memo-form-wrap" id="memoFormWrap">
      <textarea id="memoInput" placeholder="気づいたことを自由に入力..."></textarea>
      <div class="memo-form-btns">
        <button class="mcancel" id="memoCancelBtn">キャンセル</button>
        <button class="msave" id="memoSaveBtn">保存</button>
      </div>
    </div>
    <div id="memoList"></div>
  </section>

  <!-- ログ -->
  <section class="card sec" id="secLog">
    <p class="card-title">🕘 ログ（自動記録）</p>
    <div id="logList"></div>
  </section>
</section>
</div>

<!-- status fixed -->
<div class="status-bar" id="statusBar" style="display:none">
  <button id="statusBtn">ステータス変更</button>
</div>

<!-- bottom nav -->
<nav class="bnav">
  <button class="nav-on" data-nav="home">🏠<span>ホーム</span></button>
  <button data-nav="home">📋<span>物件一覧</span></button>
  <button class="nav-fab">＋<span>新規</span></button>
  <button>📊<span>比較</span></button>
  <button>⚙️<span>設定</span></button>
</nav>

<!-- status sheet -->
<div class="bd" id="sBd"></div>
<div class="sheet" id="sSheet">
  <div class="sh-handle"></div>
  <p class="sh-title">ステータス変更</p>
  <div id="sOpts"></div>
  <div class="reason-zone" id="rZone">
    <textarea id="rInput" placeholder="見送り理由を入力（任意）"></textarea>
    <button class="reason-confirm" id="rConfirm">この内容で見送りにする</button>
  </div>
  <button class="sh-cancel" id="sCancelBtn">キャンセル</button>
</div>

<!-- check sheet -->
<div class="bd" id="cBd"></div>
<div class="sheet" id="cSheet">
  <div class="sh-handle"></div>
  <p class="sh-title" id="cShTitle">調査項目</p>
  <div id="cOpts"></div>
  <button class="sh-cancel" id="cCancelBtn">キャンセル</button>
</div>

<!-- edit wizard sheet -->
<div class="bd" id="eBd"></div>
<div class="sheet" id="eSheet">
  <div class="sh-handle"></div>
  <p class="sh-title">基本情報を編集</p>
  <div class="wiz-steps" id="wizProg"></div>
  <p class="wiz-step-name" id="wizStepName"></p>
  <div id="wizFields"></div>
  <div class="wiz-nav">
    <button class="wiz-back" id="wizBack">戻る</button>
    <button class="wiz-next" id="wizNext">次へ</button>
  </div>
</div>

<!-- fullscreen photo -->
<div class="fs" id="fsView">
  <div class="fs-head">
    <button id="fsClose">✕</button>
    <span id="fsCounter"></span>
    <button id="fsAddBtn">＋</button>
  </div>
  <div class="fs-body">
    <div class="fs-track" id="fsTrack"></div>
  </div>
  <div class="fs-foot" id="fsFoot"></div>
</div>

<script>
/* ─── constants ─── */
const SM={
  候補:{e:"🟢",bg:"#dff4e5",fg:"#14733d",dot:"#1f7a45",gr:["#1f7a45","#7ecb91"]},
  調査中:{e:"🟡",bg:"#fff3d6",fg:"#8a6300",dot:"#d99a1f",gr:["#c98a12","#f3cc6f"]},
  保留:{e:"🔵",bg:"#e2eefb",fg:"#1d5fa3",dot:"#2f7bd1",gr:["#2f7bd1","#8fc0f3"]},
  見送り:{e:"⚫",bg:"#ececec",fg:"#5a5a5a",dot:"#8d8d8d",gr:["#8d8d8d","#bcbcbc"]},
  購入済:{e:"⭐",bg:"#fdf0d8",fg:"#8a5a00",dot:"#d9a528",gr:["#d9a528","#f3d27a"]}
};
const SO=["候補","調査中","保留","見送り","購入済"];

const CK={
  "雨漏り":[["未確認","bu"],["雨漏りなし","bg"],["修繕済","bg"],["現在あり","bb"]],
  "シロアリ":[["未確認","bu"],["被害なし","bg"],["防蟻処理済","bg"],["被害あり","bb"]],
