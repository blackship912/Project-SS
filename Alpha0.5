function renderGallery(p){
  const el=document.getElementById("gallery");
  if(!p.photos.length){
    el.innerHTML=`<div class="gal-empty"><button class="gal-empty-btn" id="galEmptyBtn">＋ 写真を追加</button><p>外観・室内などの写真を登録できます</p></div>`;
    document.getElementById("galEmptyBtn").addEventListener("click",triggerPick);
    return;
  }
  const n=p.photos.length;
  const dots=p.photos.map((_,i)=>`<span class="${i===galIdx?"on":""}"></span>`).join("");
  const counter=n>=6?`<span class="gal-counter" id="galCounter">${galIdx+1} / ${n}</span>`:"";
  el.innerHTML=`
    <div class="gal-viewport" id="galVP">
      <div class="gal-track" id="galTrack">
        ${p.photos.map(ph=>`<div class="gal-slide" style="background-image:url(${ph.src})"></div>`).join("")}
      </div>
      <button class="gal-add" id="galAddBtn">＋</button>
      ${counter}
      <div class="gal-dots">${dots}</div>
    </div>
    <div class="gal-meta">
      <div><b>${p.price}</b>価格</div><div><b>${p.yieldRate}</b>利回り</div><div><b>${p.age.split("（")[0]}</b>築年数</div>
    </div>
    <div class="gal-tags-area">
      <div class="gal-tags-wrap" id="galTagWrap"></div>
      <div class="gal-custom-row"><input id="galTagInput" placeholder="タグを自由入力"><button id="galTagAdd">追加</button></div>
    </div>
    <div class="gal-memo-area" id="galMemoArea"></div>`;

  document.getElementById("galAddBtn").addEventListener("click",e=>{e.stopPropagation();triggerPick();});
  document.getElementById("galTagAdd").addEventListener("click",()=>{
    const v=document.getElementById("galTagInput").value.trim(); if(!v)return;
    toggleTag(p,galIdx,v,true); document.getElementById("galTagInput").value="";
  });

  const track=document.getElementById("galTrack");
  const vp=document.getElementById("galVP");
  function goGal(i,anim=true){
    galIdx=Math.max(0,Math.min(n-1,i));
    track.style.transition=anim?"transform .32s cubic-bezier(.22,.7,.36,1)":"none";
    track.style.transform=`translateX(${-galIdx*100}%)`;
    document.querySelectorAll("#gallery .gal-dots span").forEach((d,idx)=>d.classList.toggle("on",idx===galIdx));
    const cnt=document.getElementById("galCounter");if(cnt)cnt.textContent=`${galIdx+1} / ${n}`;
    renderTagArea(p); renderPhotoMemo(p);
  }
  let sx=0,drag=false,base=0;
  vp.addEventListener("touchstart",e=>{if(e.target.id==="galAddBtn")return;sx=e.touches[0].clientX;drag=true;track.style.transition="none";base=-galIdx*vp.clientWidth;},{passive:true});
  vp.addEventListener("touchmove",e=>{if(!drag)return;track.style.transform=`translateX(${base+(e.touches[0].clientX-sx)}px)`;},{passive:true});
  vp.addEventListener("touchend",e=>{if(!drag)return;drag=false;const dx=e.changedTouches[0].clientX-sx;Math.abs(dx)>50?(dx<0?goGal(galIdx+1):goGal(galIdx-1)):goGal(galIdx);});
  vp.addEventListener("click",e=>{if(e.target.id==="galAddBtn")return;openFS(p,galIdx);});

  goGal(galIdx,false);
}

function renderTagArea(p){
  const ph=p.photos[galIdx]; if(!ph)return;
